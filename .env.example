# Copy this to .env and fill in values. Never commit .env.

# ── Bybit Demo Trading account (api.bybit.com, demo=true in config.yaml) ──────
# The bot reads these FIRST (smc_bot/bot.py), falling back to BYBIT_API_KEY/SECRET.
# Required even for paper / signal-only mode: run_cycle fetches the wallet balance
# first and skips the whole cycle if it is 0 (no keys → no signals ever logged).
BYBIT_DEMO_API_KEY=your_demo_api_key_here
BYBIT_DEMO_API_SECRET=your_demo_api_secret_here

# ── Live Bybit keys — only used if bybit.demo: false in config.yaml ───────────
# Leave blank for paper/demo. NEVER commit real keys.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Telegram alerts (optional but recommended) ───────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Execution master switch (defense in depth) ───────────────────────────────
# Owner flips to true MANUALLY to allow real order routing — never the agent.
# With LIVE_TRADING=false the executor returns synthetic PAPER results even when
# signal_only_mode is false, so no order reaches the exchange. See CLAUDE.md §1/§7.
LIVE_TRADING=false
